{
    "env": {
        "node": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
      "indent": ["error", "tab"],
      "linebreak-style": "off",
      "quotes": ["error", "single"],
      "semi": ["error", "always"],
      "no-unused-vars": ["warn"],
      "no-console": "off",
      "no-mixed-spaces-and-tabs": ["warn"],
      "no-inner-declarations": ["warn"],
      "no-useless-escape": ["warn"]
    }
}